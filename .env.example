# Production Database Configuration
DB_URL=jdbc:postgresql://your-db-host:5432/invoice_db
DB_USERNAME=postgres
DB_PASSWORD=your-secure-password-change-this

# JWT Configuration (min 256 bits / 32 bytes for HS256)
JWT_SECRET=your-256-bit-secret-key-generate-with-openssl-rand-base64-32
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Application Profile
SPRING_PROFILES_ACTIVE=prod

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Environment
APP_ENVIRONMENT=production
